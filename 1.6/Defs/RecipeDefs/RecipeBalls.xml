<Defs>

  <RecipeDef>
    <defName>PW_MakeApricornBall</defName>
    <label>make Apricorn Balls x20</label>
    <description>Make Apricorn Balls to reload belts with.</description>
    <jobString>Making Apricorn Balls.</jobString>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_MakeBow</soundWorking>
    <workAmount>1800</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <recipeUsers>
      <li>CraftingSpot</li>
    </recipeUsers>
    <researchPrerequisite>PW_ApricornBallResearch</researchPrerequisite>
    <skillRequirements>
      <Crafting>2</Crafting>
    </skillRequirements>
    <unfinishedThingDef>UnfinishedWeapon</unfinishedThingDef>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>WoodLog</li>
          </thingDefs>
        </filter>
        <count>45</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>WoodLog</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <PW_MakeableApricornBall>20</PW_MakeableApricornBall>
    </products>
  </RecipeDef>

