        <match Class="PatchOperationSequence">
            <operations>
                <li Class="PatchOperationAdd">
					<xpath>/Defs/RecipeDef[@Name= "AI_SurgeryInstallBionic_Body"]/appliedOnFixedBodyParts</xpath>
					<value>
						<li>PW_LevitatingOrMovingBody</li>
                        <li>PW_LevitatingOrMovingHead</li>
