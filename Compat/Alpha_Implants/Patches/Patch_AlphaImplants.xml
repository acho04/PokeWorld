					<xpath>/Defs/RecipeDef[@Name= "AI_SurgeryInstallProsthetic_Tentacle"]/appliedOnFixedBodyParts</xpath>
					<value>
						<li>PW_Tentacle</li>
					</value>
				</li>
                <li Class="PatchOperationAdd">
					<xpath>/Defs/RecipeDef[@Name= "AI_SurgeryInstallProsthetic_Wing"]/appliedOnFixedBodyParts</xpath>
					<value>
						<li>PW_InsectWing</li>
                        <li>PW_Wing</li>
					</value>
				</li>
            </operations>
        </match>
    </Operation>
