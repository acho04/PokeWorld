					<xpath>/Defs/RecipeDef[@Name= "AI_SurgeryInstallBionic_Wing"]/appliedOnFixedBodyParts</xpath>
					<value>
						<li>PW_InsectWing</li>
                        <li>PW_Wing</li>
					</value>
				</li>
                            <li Class="PatchOperationAdd">
					<xpath>/Defs/RecipeDef[@Name= "AI_SurgeryInstallCrude_AllLimbs"]/appliedOnFixedBodyParts</xpath>
